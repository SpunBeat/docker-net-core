# ===========================================
# Variables de entorno para MyAPI
# ===========================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
#
# NUNCA subas el archivo .env al repositorio.
# ===========================================

# --- .NET ---
ASPNETCORE_ENVIRONMENT=Development

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD
POSTGRES_DB=myapi

# --- PostgreSQL SSL ---
# Valores: Disable | Prefer | Require
# Usar "Require" en produccion
POSTGRES_SSL_MODE=Prefer

# --- Puertos ---
API_PORT=8080
DB_PORT=5432
